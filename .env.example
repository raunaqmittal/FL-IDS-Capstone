# .env.example — Environment variable template.
# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit secrets to version control.

# ─── Data Paths ──────────────────────────────────────────────────
# Absolute path to the directory containing raw CIC-IDS2017 CSV files.
# Download from: https://www.unb.ca/cic/datasets/ids-2017.html
RAW_DATA_PATH=/path/to/CIC-IDS-2017/

# ─── Experiment Control ───────────────────────────────────────────
# Overrides config.yaml when set. Leave blank to use config.yaml values.
ATTACKER_RATIO=
ATTACK_TYPE=
NUM_ROUNDS=
NUM_CLIENTS=

# ─── Flower Server ────────────────────────────────────────────────
# Only needed when running distributed (non-simulation) mode.
FLOWER_SERVER_ADDRESS=0.0.0.0:8080

# ─── Reproducibility ─────────────────────────────────────────────
RANDOM_SEED=42

# ─── Logging ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
